---
import { getCollection } from 'astro:content'
import Item from '../../../components/Item.astro'
import ItemsWrapper from '../../../components/ItemsWrapper.astro'
import Layout from '../../../layouts/Layout.astro'

const all = await getCollection('products')
const sweatshirts = all.filter(p => p.data.category === 'sweatshirts')
---

<Layout title="Талстоўки">
	<h1>Талстоўки</h1>
	<ItemsWrapper>
		{sweatshirts.map(i => <Item item={i} />)}
	</ItemsWrapper>
</Layout>

