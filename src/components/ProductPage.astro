---
import type { CollectionEntry, RenderResult } from 'astro:content'

interface Props {
  item: CollectionEntry<'products'>
  Content: RenderResult['Content']
}

const { item, Content } = Astro.props
const { title, sizes, price, currency, material, composition, country, manufacturer } = item.data
---

<div class="product-page">
  <div class="product-page-wrapper">
    <div class="image"></div>
    <div class="product-content">
      <h1>{title}</h1>
      {sizes && sizes.length > 0 && (
        <div class="size-selector">
          <label for="size-select">Абярыце памер:</label>
          <select name="size" id="size-select">
            {sizes.map((size) => (
              <option value={size}>{size}</option>
            ))}
          </select>
        </div>
      )}
      <p class="price">{price} {currency}</p>
      <p><strong>Матэрыял:</strong> {material}</p>
      <p><strong>Склад:</strong> {composition}</p>
      <div class="markdown-body">
        <Content />
      </div>
      <p><strong>Краіна вытворчасці:</strong> {country}</p>
      <p><strong>Вытворэц:</strong> {manufacturer}</p>
    </div>
  </div>
</div>

<style>
.product-page {
		margin: 0 auto;
	}

	.product-page-wrapper {
		display: flex;
		flex-direction: column;
		gap: 30px;
		max-width: 1280px;

		@media (width >= 768px) {
			justify-content: center;
			margin: 0 auto;
			flex-direction: row;
			align-items: start;
		}
	}

	.product-content {
		display: flex;
		flex-direction: column;
	}

	.image {
		width: 100%;
		height: auto;         
		aspect-ratio: 1 / 1; 
		background-color: lightgray;
		margin-bottom: 20px;

		@media (width >= 768px) {
			max-width: 560px;
			margin-bottom: 0;
		}
	}

	.size-selector {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin-bottom: 15px;
	}

	.size-selector select {
		padding: 8px;
		font-size: 16px;
		border-radius: 4px;
		border: 1px solid transparent;
		max-width: 200px;
		cursor: pointer;
	}

	.markdown-body :global(ul) {
		list-style: none; 
		padding: 0;       
		margin: 0;
	}

	.markdown-body :global(li) {
		margin-bottom: 8px; 
	}

	.markdown-body :global(h3) {
		margin-top: 20px;
	}
</style>