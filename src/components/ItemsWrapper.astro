<div class="items-wrapper">
	<slot />
</div>

<style>
	.items-wrapper {
	display: grid;
	grid-template-columns: 1fr;
	gap: 20px; 
	margin-top: 20px;
}

@media (width >= 768px) {
	.items-wrapper {
		grid-template-columns: 1fr 1fr;
		gap: 25px;
	}
}

@media (width >= 1024px) {
	.items-wrapper {
		grid-template-columns: 1fr 1fr 1fr 1fr; 
		gap: 30px;
	}
}
</style>