---
import type { CollectionEntry } from 'astro:content'

interface Props {
  item: CollectionEntry<'products'>
}

const { item } = Astro.props
const { title, description, price, currency, isOnSale, category } = item.data
---

<div class="container">
  <a class="link" href={`/catalog/${category}/${item.id}`}>
    <div class="image"></div>
    <div class="title">{title}</div>
    <div class="description">{description}</div>
    <div class="price">
      {price} {currency}
    </div>
		{isOnSale && <span class="badge">Sale</span>}
  </a>
</div>

<style>
	.link {
		text-decoration: none;
		color: initial;
		width: 100%;
		position: relative;
		
	}

	.badge {
		position: absolute;
		background-color: red;
		top: 5px;
		right: 5px;
		border-radius: 50%;
		width: 50px;
		height: 50px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
	}

	.image {
    width: 100%;          
    height: auto;         
    aspect-ratio: 1 / 1;  
    background-color: lightgray;
		margin-bottom: 10px;

		@media (width >= 640px) {
			margin-bottom: 20px;
		}
	}

	.container {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
	}

	.title {
		font-weight: 600;
	}

	.description {
		font-weight: 300;
		font-size: 16px;
	}
</style>